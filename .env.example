# Copy this file to .env and fill in your credentials.
# NEVER commit .env to version control!

# ─── Binance LIVE (Main Account) ────────────────────────────
BINANCE_API_KEY=your_live_api_key_here
BINANCE_SECRET_KEY=your_live_secret_key_here

# ─── Binance TESTNET (Paper Trading) ────────────────────────
BINANCE_TESTNET_API_KEY=your_testnet_api_key_here
BINANCE_TESTNET_SECRET_KEY=your_testnet_secret_key_here

# ─── Mode ───────────────────────────────────────────────────
# Set to "testnet" for paper trading, "live" for real money
TRADING_MODE=testnet
