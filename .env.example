# Copy this file to `.env` and populate with real secrets.
# Never commit `.env`.

# =========================================
# OKX (primary exchange)
# =========================================
OKX_API_KEY=your_okx_live_api_key_here
OKX_SECRET_KEY=your_okx_live_secret_key_here
OKX_PASSPHRASE=your_okx_live_passphrase_here

# OKX testnet/sandbox
OKX_TESTNET_API_KEY=your_okx_testnet_api_key_here
OKX_TESTNET_SECRET_KEY=your_okx_testnet_secret_key_here
OKX_TESTNET_PASSPHRASE=your_okx_testnet_passphrase_here

# =========================================
# Optional Binance keys (legacy/reference)
# =========================================
BINANCE_API_KEY=
BINANCE_SECRET_KEY=
BINANCE_TESTNET_API_KEY=
BINANCE_TESTNET_SECRET_KEY=

# =========================================
# Trading mode
# =========================================
TRADING_MODE=testnet
LIVE_BASELINE_MODEL_DIR=models/live_baseline
LIVE_SESSION_TIMEZONE=Asia/Bangkok
UI_USERNAME=
UI_PASSWORD=
UI_SESSION_SECRET=change-me-before-deploy
UI_BIND_HOST=127.0.0.1
UI_PORT=8080
UI_TAIL_LINES_DEFAULT=200
UI_LOGIN_RATE_LIMIT=5
UI_ENABLE_CONTROLS=false
UI_TRUST_TAILSCALE_HEADERS=false
UI_ALLOWED_TAILSCALE_USERS=
UI_ADMIN_TAILSCALE_USERS=

# =========================================
# Optional LLM provider keys for integrations
# Research default is local Ollama only; no hosted LLM key is required.
# =========================================
OPENAI_API_KEY=
OPENAI_BASE_URL=
OPENAI_MODEL=
GROQ_API_KEY=
GROQ_BASE_URL=https://api.groq.com/openai/v1
GROQ_MODEL=
OLLAMA_BASE_URL=http://localhost:11434/v1
OLLAMA_MODEL=qwen3.5:4b-gpu8k
OLLAMA_VULKAN=1
XAI_API_KEY=

# =========================================
# Optional LLM risk-gate tuning (local Ollama)
# =========================================
LLM_RISK_GATE_MODEL=qwen3.5:4b-gpu8k
LLM_RISK_GATE_CADENCE=weekly
LLM_RISK_GATE_CACHE_TTL=604800
LLM_RISK_GATE_MAX_CALLS_PER_DAY=8
LLM_RISK_GATE_MODE=de_risk
LLM_RISK_GATE_TIMEOUT_SECS=5

# =========================================
# Backtest/training realism controls
# Defaults preserve the current research baseline.
# =========================================
SLIPPAGE_MODEL=flat
SLIPPAGE_VOL_WINDOW=24
SLIPPAGE_VOL_SCALAR=10
SLIPPAGE_VOL_CAP_MULT=3

KILL_SWITCH_ENABLED_EVAL=false
KILL_SWITCH_DRAWDOWN_THRESHOLD=-0.15

STEP_TURNOVER_CAP_ENABLED=false
STEP_TURNOVER_CAP_NORMAL=0.20
STEP_TURNOVER_CAP_STRESS=0.12
STEP_TURNOVER_CAP_CRISIS=0.08

# Promoted execution-control baseline from the live-ready champion.
REBALANCE_THRESHOLD_NORMAL=0.03
REBALANCE_THRESHOLD_STRESS=0.05
REBALANCE_THRESHOLD_CRISIS=0.08
MIN_HOLD_BARS=4
MATERIAL_TRADE_THRESHOLD=0.05
REVERSAL_HYSTERESIS_MULT=1.5
POSITION_RESET_WEIGHT_THRESHOLD=0.05
POSITION_RESET_PERSIST_BARS=2

# Optional reward/governor variant controls for controlled experiments.
REWARD_PROFIT_WEIGHT=1.0
REWARD_SHARPE_WEIGHT=0.0
REWARD_DRAWDOWN_WEIGHT=10.0
REWARD_TURNOVER_WEIGHT=1.0
REWARD_MISSED_OPPORTUNITY_WEIGHT=0.5
REWARD_TAIL_LOSS_WEIGHT=2.0
RISK_GOVERNOR_ENABLED=true
RISK_GOVERNOR_STRESS_MAX_RISK_ON=0.75
RISK_GOVERNOR_CRISIS_MAX_RISK_ON=0.55
